# Bloodfy Environment Variables
# Copy this file to .env and fill in your values

# Django Settings
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production-minimum-50-chars
ALLOWED_HOSTS=localhost,127.0.0.1

# Database - SQLite (default) or MySQL
# For SQLite, leave DATABASE_URL empty
# For MySQL: mysql://user:password@localhost:3306/bloodfy_db
DATABASE_URL=

# MySQL Settings (if using MySQL instead of SQLite)
DATABASE_NAME=bloodfy_db
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_HOST=localhost
DATABASE_PORT=3306

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# Twilio SMS Settings
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Dialogflow Settings
DIALOGFLOW_PROJECT_ID=your_dialogflow_project_id
GOOGLE_APPLICATION_CREDENTIALS=path/to/dialogflow-credentials.json

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Email Settings (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
EMAIL_USE_TLS=True

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500
